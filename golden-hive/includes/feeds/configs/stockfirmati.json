{
    "_comment": "StockFirmati — CSV pipe-delimited con righe PRODUCT + MODEL",
    "id": "stockfirmati",
    "name": "StockFirmati",
    "version": "1.1",

    "source": {
        "format": "csv",
        "delimiter": "|",
        "encoding": "utf-8"
    },

    "row_types": {
        "enabled": true,
        "column": "RECORD_TYPE",
        "parent_type": "PRODUCT",
        "variant_type": "MODEL",
        "link_column": "SKU"
    },

    "_pricing_notes": {
        "STREET_PRICE": "Prezzo di listino (retail) → diventa regular_price (barrato)",
        "PRICE": "Costo all'ingrosso → moltiplicato per markup → diventa sale_price",
        "markup_percentage": "Cambia il valore 'multiply' in sale_price.transforms",
        "vat_percentage": "Cambia il valore 'multiply' in sale_price.transforms (es: per IVA 22% aggiungi step multiply 1.22)",
        "example": "PRICE=24.89 × 3.5 markup = 87.12€ sale_price. STREET_PRICE=162.00€ = regular_price"
    },

    "product": {
        "sku": "SKU",
        "name": {
            "column": "Titel_ITA",
            "fallback": "{BRAND} {MODEL_NAME}"
        },
        "description": "Description_ITA",
        "weight": "WEIGHT",
        "status": { "static": "publish" },

        "regular_price": {
            "column": "STREET_PRICE",
            "transforms": [{ "type": "round", "value": 0 }]
        },
        "sale_price": {
            "column": "PRICE",
            "transforms": [
                { "type": "multiply", "value": 3.5, "_comment": "markup: wholesale × 3.5 = selling price" },
                { "type": "round", "value": 0 }
            ]
        },
        "price_logic": "sale_below_regular"
    },

    "variations": {
        "size_column": "MODEL_SIZE",
        "quantity_column": "QUANTITY",
        "attribute": "pa_taglia",
        "sku_suffix": "-{size_slug}",
        "per_variation_price": true,
        "extra_fields": {
            "barcode": "BARCODE",
            "ean": "EAN"
        }
    },

    "taxonomy": {
        "brand": {
            "target": "product_brand",
            "column": "BRAND"
        },
        "category": {
            "target": "product_cat",
            "parent_column": "CAT",
            "child_column": "SUBCAT"
        },
        "tags": [
            { "static": "stockfirmati" },
            {
                "column": "STAGIONE",
                "lookup": {
                    "AI": "autunno-inverno",
                    "PE": "primavera-estate",
                    "TS": "continuativo"
                }
            }
        ]
    },

    "images": {
        "columns": ["PICTURE_1", "PICTURE_2", "PICTURE_3"],
        "first_is_featured": true,
        "rest_is_gallery": true,
        "filename_pattern": "{sku}-{index}.{ext}"
    },

    "meta": {
        "_feed_source": { "static": "stockfirmati" },
        "_sf_color": "COLOR",
        "_sf_material": "MATERIAL",
        "_sf_made_in": "MADE_IN",
        "_sf_sex": "SEX",
        "_sf_cost_price": "PRICE",
        "_sf_source_url": "Product_url"
    }
}
